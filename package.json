{
  "name": "peekly",
  "version": "0.4.0",
  "description": "Hold x to inspect any component, DOM element, or CSS. Press y for the Network Inspector — fast, seamless, on any site.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Romario Sobreira <romario.sobreira@hotmail.com>",
  "homepage": "https://github.com/rosoam/peekly",
  "repository": {
    "type": "git",
    "url": "https://github.com/rosoam/peekly.git"
  },
  "bugs": {
    "url": "https://github.com/rosoam/peekly/issues"
  },
  "keywords": [
    "react",
    "devtools",
    "chrome-extension",
    "browser-extension",
    "component-inspector",
    "react-fiber",
    "developer-tools",
    "dom-inspector",
    "manifest-v3"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "gen:icons": "bun run scripts/gen-icons.ts",
    "zip": "bun run build && cd dist && zip -r ../peekly.zip .",
    "release": "bun run scripts/release.ts",
    "release:patch": "bun run scripts/release.ts patch",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major",
    "demo:install": "cd demo && bun install",
    "demo:dev": "cd demo && bun run dev",
    "demo:build": "cd demo && bun run build",
    "screenshots": "bun run scripts/screenshots.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.270",
    "bun-types": "^1.3.13",
    "playwright": "^1.49.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
